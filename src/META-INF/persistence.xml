<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
    xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="proyectosFP" transaction-type="RESOURCE_LOCAL">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <class>modelo.entities.Cliente</class>
        <class>modelo.entities.Familia</class>
        <class>modelo.entities.Producto</class>
        <class>modelo.entities.Factura</class>
        <class>modelo.entities.Proyecto</class>
        <class>modelo.entities.ProyectoConProductos</class>
        <class>modelo.entities.Departamento</class>
        <class>modelo.entities.Empleado</class>
        <class>modelo.entities.Perfil</class>
        <class>modelo.entities.ProyectoConEmpleados</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver" />
            <property name="jakarta.persistence.jdbc.url"
                value="jdbc:mysql://localhost:3306/proyectos_FP_2025" />
            <property name="jakarta.persistence.jdbc.user" value="root" />
            <property name="jakarta.persistence.jdbc.password" value="root" />


            <property name="eclipselink.logging.level" value="INFO" />
            <property name="eclipselink.target-database" value="MySQL" />
        </properties>
    </persistence-unit>
</persistence>